generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  protocolo      String    @id
  assunto        String    @default("")
  status         String    @default("")
  grupo          String    @default("")
  consultor      String    @default("")
  modulo         String    @default("")
  cliente        String    @default("")
  abertura       DateTime
  primeirTramite DateTime?
  ultimoTramite  DateTime?
  conclusao      DateTime?
  slaStatus      String    @default("pendente")
  slaHorasUteis  Float?
  coletadoEm     DateTime  @default(now()) @updatedAt

  @@index([grupo, consultor])
  @@index([abertura])
  @@index([status])
  @@index([slaStatus])
  @@index([conclusao])
}

model Chamada {
  id           String   @id @default(cuid())
  dataHora     DateTime
  fila         String   @default("")
  origemNome   String   @default("")
  origemNumero String   @default("")
  ramal        String   @default("")
  agente       String   @default("")
  tempoEspera  Int      @default(0)   // segundos
  duracao      Int      @default(0)   // segundos
  encerradaPor String   @default("")
  categoria    String   @default("atendida") // atendida|abandonada|excedida|desconectada
  coletadoEm   DateTime @default(now())

  // Chave de deduplicação (não há ID nativo no relatório do vpabx)
  @@unique([dataHora, fila, ramal, origemNumero, categoria], name: "chamada_uniq")
  @@index([dataHora])
  @@index([fila])
  @@index([agente])
  @@index([categoria])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
}

model ColecaoLog {
  id           String    @id @default(cuid())
  iniciadoEm   DateTime  @default(now())
  concluidoEm  DateTime?
  ticketsNovos Int       @default(0)
  ticketsSla   Int       @default(0)
  totalTickets Int       @default(0)
  status       String    @default("em_andamento")
  erro         String?
}
